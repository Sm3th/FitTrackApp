{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile"
  },
  "deploy": {
    "startCommand": "ls -la /app/dist/ 2>&1 && ./node_modules/.bin/prisma db push --skip-generate --accept-data-loss 2>&1 && node /app/dist/src/server.js 2>&1",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
